  "datasets": [
    {
      "table_name": "mart_hourly_kpi",
      "schema": "nyc_tlc_gold",
      "database": "nyc_tlc_athena",
      "sql": "",
      "description": "Pre-aggregated hourly KPI OBT — primary source for all dashboard charts.",
      "columns": [
        { "column_name": "pickup_date",      "type": "DATE",    "is_dttm": true },
        { "column_name": "pickup_hour",      "type": "INTEGER", "is_dttm": false },
        { "column_name": "cab_type",         "type": "VARCHAR", "is_dttm": false },
        { "column_name": "pickup_zone",      "type": "VARCHAR", "is_dttm": false },
        { "column_name": "dropoff_zone",     "type": "VARCHAR", "is_dttm": false },
        { "column_name": "borough",          "type": "VARCHAR", "is_dttm": false },
        { "column_name": "payment_type",     "type": "VARCHAR", "is_dttm": false },
        { "column_name": "trip_count",       "type": "BIGINT",  "is_dttm": false },
        { "column_name": "total_revenue",    "type": "DOUBLE",  "is_dttm": false },
        { "column_name": "avg_fare_amount",  "type": "DOUBLE",  "is_dttm": false },
        { "column_name": "avg_trip_distance","type": "DOUBLE",  "is_dttm": false },
        { "column_name": "avg_duration_min", "type": "DOUBLE",  "is_dttm": false },
        { "column_name": "avg_tip_amount",   "type": "DOUBLE",  "is_dttm": false }
      ],
      "metrics": [
        {
          "metric_name": "total_trips",
          "expression": "SUM(trip_count)",
          "description": "Total number of trips in the selected period"
        },
        {
          "metric_name": "total_revenue",
          "expression": "SUM(total_revenue)",
          "description": "Sum of all fare revenue"
        },
        {
          "metric_name": "avg_fare",
          "expression": "AVG(avg_fare_amount)",
          "description": "Average fare amount per trip"
        },
        {
          "metric_name": "avg_distance_mi",
          "expression": "AVG(avg_trip_distance)",
          "description": "Average trip distance in miles"
        },
        {
          "metric_name": "avg_duration_minutes",
          "expression": "AVG(avg_duration_min)",
          "description": "Average trip duration in minutes"
        }
      ]
    }
  ],
